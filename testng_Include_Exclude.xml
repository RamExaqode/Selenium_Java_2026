<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Loan Department">

  <!-- Test 1: Personal Loan -->
  <test name="Personal Loan">
    <classes>

      <class name="testng.Day1">
        <methods>
          <!-- Run only this method -->
          <include name="secondTestCase"/>
        </methods>
      </class>

      <class name="testng.Day2"/>
	  <class name="testng.TestNG_Annotations"/>
	  <class name="testng.TestBG_DataProvider"/>
    </classes>
  </test>

  <!-- Test 2: Car Loan -->
  <test name="Car Loan">
    <classes>

      <class name="testng.Day3">
        <methods>
          <!-- Exclude specific method -->
          <include name="MobileLoginCarLoan"/>
        </methods>
      </class>

    </classes>
  </test>

  <!-- Test 3: Home Loan -->
  <test name="Home Loan">
    <classes>

      <class name="testng.Day5">
        <methods>
          <!-- Exclude all methods starting with 'Mobile' -->
          <exclude name="Mobile.*"/>
        </methods>
      </class>

      <class name="testng.Day2"/>

    </classes>
  </test>

</suite>